{
  "version": "1.0.0",
  "providers": [
    {
      "id": "deepseek",
      "name": "DeepSeek",
      "base_url": "https://api.deepseek.com",
      "description": "DeepSeek AI 提供的高性能模型",
      "models": [
        {
          "id": "deepseek-chat",
          "name": "DeepSeek Chat",
          "max_tokens": 8192,
          "description": "通用对话模型，适合各类内容生成任务"
        },
        {
          "id": "deepseek-coder",
          "name": "DeepSeek Coder",
          "max_tokens": 8192,
          "description": "专为代码生成优化的模型"
        }
      ],
      "defaults": {
        "max_retries": 3,
        "timeout": 120,
        "temperature": 0.1,
        "top_p": 0.7
      }
    },
    {
      "id": "openai",
      "name": "OpenAI",
      "base_url": "https://api.openai.com/v1",
      "description": "OpenAI GPT 系列模型",
      "models": [
        {
          "id": "gpt-4",
          "name": "GPT-4",
          "max_tokens": 8192,
          "description": "最强大的 GPT-4 模型"
        },
        {
          "id": "gpt-4-turbo",
          "name": "GPT-4 Turbo",
          "max_tokens": 128000,
          "description": "更快速的 GPT-4 版本，支持更长上下文"
        },
        {
          "id": "gpt-3.5-turbo",
          "name": "GPT-3.5 Turbo",
          "max_tokens": 16385,
          "description": "高性价比的对话模型"
        }
      ],
      "defaults": {
        "max_retries": 3,
        "timeout": 60,
        "temperature": 0.1,
        "top_p": 0.7
      }
    },
    {
      "id": "anthropic",
      "name": "Anthropic (Claude)",
      "base_url": "https://api.anthropic.com/v1",
      "description": "Anthropic Claude 系列模型",
      "models": [
        {
          "id": "claude-3-opus-20240229",
          "name": "Claude 3 Opus",
          "max_tokens": 4096,
          "description": "最强大的 Claude 3 模型"
        },
        {
          "id": "claude-3-sonnet-20240229",
          "name": "Claude 3 Sonnet",
          "max_tokens": 4096,
          "description": "平衡性能和成本的 Claude 3 模型"
        },
        {
          "id": "claude-3-haiku-20240307",
          "name": "Claude 3 Haiku",
          "max_tokens": 4096,
          "description": "最快速的 Claude 3 模型"
        }
      ],
      "defaults": {
        "max_retries": 3,
        "timeout": 90,
        "temperature": 0.1,
        "top_p": 0.7
      }
    },
    {
      "id": "custom",
      "name": "自定义提供商",
      "base_url": "",
      "description": "配置自定义的 OpenAI 兼容 API",
      "models": [],
      "defaults": {
        "max_retries": 3,
        "timeout": 120,
        "temperature": 0.1,
        "top_p": 0.7
      },
      "allow_custom_model": true,
      "allow_custom_base_url": true
    }
  ]
}
